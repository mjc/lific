{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.VoidNullable/lific",
  "title": "Lific",
  "description": "Local-first, lightweight issue tracker. Single binary, SQLite-backed, MCP-native.",
  "websiteUrl": "https://github.com/VoidNullable/lific",
  "repository": {
    "url": "https://github.com/VoidNullable/lific",
    "source": "github"
  },
  "version": "2.2.1",
  "packages": [
    {
      "registryType": "cargo",
      "registryBaseUrl": "https://crates.io",
      "identifier": "lific",
      "version": "2.2.1",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ]
}
